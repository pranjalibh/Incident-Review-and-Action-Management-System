pipeline {
  agent any

  triggers {
    pollSCM('H/3 * * * *') // every 3 minutes
  }

  environment {
    GITHUB_TOKEN = credentials('github-token')
  }

  tools {
    maven 'Maven_3'
  }

  parameters {
    booleanParam(
      name: 'RUN_UI_TESTS',
      defaultValue: false,
      description: 'Run Selenium UI tests'
    )
  }

  stages {

    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Build') {
      steps {
        bat 'mvn clean compile'
      }
    }

    stage('Unit Tests') {
      steps {
        bat 'mvn test'
      }
    }

    stage('API Tests') {
      steps {
        bat 'mvn verify -DskipUnitTests=true'
      }
    }

    stage('UI Tests (Selenium)') {
      when {
        expression { return params.RUN_UI_TESTS }
      }
      steps {
        bat 'mvn verify -DskipUnitTests=true -DskipApiTests=true'
      }
    }

    stage('Secure Step') {
      steps {
        bat 'echo "Token injected securely"'
      }
    }
  }

  post {
    always {
      junit allowEmptyResults: true, testResults: '''
        target/surefire-reports/*.xml,
        target/failsafe-reports/*.xml
      '''



      publishHTML(target: [
        reportDir: 'target/site/jacoco',
        reportFiles: 'index.html',
        reportName: 'JaCoCo Code Coverage',
        keepAll: true,
        alwaysLinkToLastBuild: true
      ])
    }
  }
}